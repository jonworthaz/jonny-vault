# Copy to .env and fill in. The engine runs fully offline without these
# (deterministic synthesis), and automatically uses the real Claude API when set.

# Anthropic API key — enables live AI generation in the loops.
ANTHROPIC_API_KEY=

# Model + effort for the AI workforce. Defaults shown.
ENGINE_MODEL=claude-opus-4-8
ENGINE_EFFORT=medium

# Soft monthly token-spend warning on the dashboard (USD).
ENGINE_BUDGET_USD=50

# Optional: use non-Claude models for modules set to --provider custom.
# Any OpenAI-compatible endpoint (OpenAI, OpenRouter, local server, etc.).
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_API_KEY=
